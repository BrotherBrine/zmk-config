/*
 * Dactyl Manuform 5x6 — Shared shield definition
 *
 * Physical layout per half:
 *   5 main rows × 6 columns = 30 keys
 *   6 thumb keys (2 rows × 3 cols) wired into row 5
 *   Total: 36 keys per half, 72 keys combined
 *
 * Matrix logical addressing:
 *   Cols  0-5  = left half
 *   Cols  6-11 = right half
 *   Rows  0-4  = main finger cluster
 *   Row   5    = thumb cluster (cols 0-2 inner, 3-5 outer per side)
 *
 * Keymap position order (matches bindings array in .keymap):
 *   Row 0:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   (12 keys)
 *   Row 1:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   (12 keys)
 *   Row 2:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   (12 keys)
 *   Row 3:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   (12 keys)
 *   Row 4:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   (12 keys)
 *   Thumb:  LI0 LI1 LI2             |  RI0 RI1 RI2               (6 keys, inner row)
 *           LO0 LO1 LO2             |  RO0 RO1 RO2               (6 keys, outer row)
 *   Total: 72 keys
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;

        /*
         * The map lists RC(row, col) entries in the order keys appear
         * in the keymap bindings array. Left half uses cols 0-5,
         * right half uses cols 6-11.
         *
         * Thumb cluster (row 5):
         *   Inner row: cols 0-2 (left),  cols 6-8  (right)
         *   Outer row: cols 3-5 (left),  cols 9-11 (right)
         *
         * Adjust thumb col numbering below to match your physical wiring.
         */
        map = <
/* Row 0 — number/symbol row */
RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)    RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11)
/* Row 1 — QWERTY top row */
RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)    RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11)
/* Row 2 — Home row */
RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)    RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11)
/* Row 3 — Bottom row */
RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)    RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11)
/* Row 4 — Modifier/nav row */
RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)    RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10) RC(4,11)
/* Row 5 — Thumb cluster, inner row */
                  RC(5,0)  RC(5,1)  RC(5,2)              RC(5,6)  RC(5,7)  RC(5,8)
/* Row 5 — Thumb cluster, outer row */
                  RC(5,3)  RC(5,4)  RC(5,5)              RC(5,9)  RC(5,10) RC(5,11)
        >;
    };
};
