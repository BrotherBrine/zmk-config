/*
 * Ortho 4x6 — Shared shield definition
 *
 * Physical layout per half:
 *   4 rows × 6 main columns = 24 keys
 *   2 thumb keys per half wired into the bottom row (row 0) via
 *   dedicated thumb columns (cols 6-7 left, cols 14-15 right)
 *   Total: 26 keys per half, 52 keys combined
 *
 * Wiring: row2col
 *   Diode anode → row wire, cathode (banded end) → column wire
 *   Row pins are driven outputs; column pins are sensed inputs.
 *
 * Matrix logical addressing:
 *   Cols  0-5   = left main  (pinky → index)
 *   Cols  6-7   = left thumb
 *   Cols  8-13  = right main (index → pinky, reversed for symmetry)
 *   Cols  14-15 = right thumb
 *   Rows  0-3   = bottom → top
 *
 * Keymap position order:
 *   Row 3:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   pos  0-11
 *   Row 2:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   pos 12-23
 *   Row 1:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   pos 24-35
 *   Row 0:  L0  L1  L2  L3  L4  L5  |  R0  R1  R2  R3  R4  R5   pos 36-47
 *   Thumb:              LT0 LT1     |  RT0 RT1                   pos 48-51
 *   Total: 52 keys
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <4>;

        map = <
/* Row 3 — top row */
RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)    RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15) 
/* Row 2 */
RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)    RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) 
/* Row 1 */
RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)    RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) 
/* Row 0 — bottom row, main keys */
RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)    RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) 
/* Row 0 — bottom row, thumb columns */
                            RC(0,6)  RC(0,7)              RC(0,8) RC(0,9)
        >;
    };
};
