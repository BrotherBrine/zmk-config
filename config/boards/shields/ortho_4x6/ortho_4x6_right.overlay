/*
 * Ortho 4x6 ‚Äî Right half GPIO configuration
 *
 * Rows (bottom ‚Üí top):  P1.06, P1.04, P0.11, P1.00
 * Your physical cols outside‚Üíinside: P0.29, P0.24, P0.22, P1.15, P1.13, P1.11, P0.10, P0.09
 *
 * Cols listed here inside‚Üíoutside so that combined cols 8-13 go
 * index‚Üípinky, matching the left half's pinky‚Üíindex order for keymap symmetry.
 * Thumb cols (C6, C7) follow after the main cols.
 *
 * Combined matrix mapping:
 *   Local C0 ‚Üí combined col  8  (right index, innermost main)
 *   Local C5 ‚Üí combined col 13  (right pinky, outermost main)
 *   Local C6 ‚Üí combined col 14  (thumb RT0)
 *   Local C7 ‚Üí combined col 15  (thumb RT1)
 *
 * Diode direction: row2col
 */

#include "ortho_4x6.dtsi"

/ {
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "row2col";

        row-gpios
            = <&gpio1 6  GPIO_ACTIVE_HIGH>   /* R0 ‚Äî bottom row (main + thumb) */
            , <&gpio1 4  GPIO_ACTIVE_HIGH>   /* R1 */
            , <&gpio0 11 GPIO_ACTIVE_HIGH>   /* R2 */
            , <&gpio1 0  GPIO_ACTIVE_HIGH>   /* R3 ‚Äî top row */
            ;

        col-gpios
            = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C0 ‚Äî innermost main (index) ‚Üí combined col  8 */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C1 ‚Üí combined col  9 */
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C2 ‚Üí combined col 10 */
            , <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C3 ‚Üí combined col 11 */
            , <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C4 ‚Üí combined col 12 */
            , <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C5 ‚Äî outermost (pinky)  ‚Üí combined col 13 */
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C6 ‚Äî thumb RT0 ‚Üí combined col 14 */
            , <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* C7 ‚Äî thumb RT1 ‚Üí combined col 15 */
            ;
    };
};
